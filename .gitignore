# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Dataset cache
data/

# Large extracted features
outputs/features/
*.npy

# Model checkpoints
outputs/checkpoints/
experiments/**/checkpoints/
*.pt
*.pth

# Logs and temporary files
*.log

# Keep important result summaries and figures
!outputs/results/
!outputs/results/results.csv
!outputs/figures/
!outputs/figures/*.png
!report_assets/
!report_assets/result_tables/
