# =========================
# Python cache
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/
.vla311/
.vscode/
.idea/

# =========================
# OS / editor files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Logs / temporary files
# =========================
*.log
logs/
tmp/
temp/

# =========================
# Dataset cache
# LeRobot / Hugging Face downloaded dataset should NOT be committed
# =========================
data/aloha/
data/**/.cache/
.cache/
.cache*/
huggingface/
hf_cache/

# =========================
# Large extracted feature files
# Regenerated by: python src/02_extract_features.py
# =========================
outputs/features/

# =========================
# Model checkpoints
# Regenerated by: python src/06_train_mlp.py
# =========================
outputs/checkpoints/
*.pt
*.pth
*.ckpt

# =========================
# Archived experiment checkpoints only
# Keep experiment notes/results/figures, ignore model weights
# =========================
experiments/*/checkpoints/
experiments/**/*.pt
experiments/**/*.pth
experiments/**/*.ckpt

# =========================
# Raw media files
# Dataset videos should not be committed
# =========================
*.mp4
*.avi
*.mov
*.mkv
*.webm

# =========================
# Large binary arrays from feature extraction only
# Do NOT ignore all *.npy globally, because selected_indices_*.npy are useful and small
# =========================
outputs/features/*.npy

# =========================
# Keep these tracked
# =========================
!outputs/results/
!outputs/results/*.csv
!outputs/results/*.json
!outputs/results/*.npy

!outputs/figures/
!outputs/figures/*.png

!report_assets/
!report_assets/result_tables/
!report_assets/result_tables/*.csv
!report_assets/result_tables/*.md

!experiments/
!experiments/*/
!experiments/*/experiment_note.md
!experiments/*/file_manifest.json
!experiments/*/README_snapshot.md
!experiments/*/results/
!experiments/*/results/*.csv
!experiments/*/results/*.json
!experiments/*/results/*.npy
!experiments/*/figures/
!experiments/*/figures/*.png
!experiments/*/report_assets/
!experiments/*/report_assets/**