!experiments/**/file_manifest.json
!experiments/**/README_snapshot.md
!experiments/**/figures/
!experiments/**/figures/*.png
!experiments/**/results/
!experiments/**/results/results.csv
!experiments/**/report_assets/
!experiments/**/report_assets/result_tables/
